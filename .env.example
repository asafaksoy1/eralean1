# Copy to .env.local for local dev, and set these in Vercel for production.
# These are read ONLY by the api/subscribe.ts serverless function — never the
# browser — so they are NOT prefixed with VITE_ and are never exposed client-side.

# MailerLite API token: MailerLite → Integrations → MailerLite API → generate.
MAILERLITE_API_TOKEN=

# Numeric group new audit leads are added to: MailerLite → Subscribers →
# Groups → open the group → the id is in the URL (.../groups/<ID>/...).
MAILERLITE_GROUP_ID=

# Slack or Discord Incoming Webhook URL. When set, every captured audit lead
# fires an instant notice here so Asaf can follow up fast. Leave empty to
# disable (the code no-ops). Slack: Apps → Incoming Webhooks → Add to a channel.
# Discord: Channel → Edit → Integrations → Webhooks → New Webhook → Copy URL.
LEAD_NOTIFY_WEBHOOK_URL=
